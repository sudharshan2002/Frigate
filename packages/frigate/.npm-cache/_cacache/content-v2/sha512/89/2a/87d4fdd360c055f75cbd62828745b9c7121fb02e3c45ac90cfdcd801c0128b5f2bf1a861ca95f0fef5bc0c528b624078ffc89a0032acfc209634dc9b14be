('#output-data').html(result);\n   })\n</pre>\n","maintainers":[{"name":"sqro2","email":"xyup.co@gmail.com"}],"time":{"modified":"2022-06-18T03:40:28.047Z","created":"2016-09-20T08:22:57.039Z","1.0.0":"2016-09-20T08:22:57.039Z"},"homepage":"https://github.com/sqro2/frigate#readme","keywords":["html","preprocessor","frigate","preprocessor","frigate.js"],"repository":{"type":"git","url":"git+https://github.com/sqro2/frigate.git"},"author":{"name":"Akshay Bordoloi","email":"xyup.co@gmail.com","url":"http://www.htmlai.com"},"bugs":{"url":"https://github.com/sqro2/frigate/issues"},"license":"MIT","readmeFilename":"README.md"}